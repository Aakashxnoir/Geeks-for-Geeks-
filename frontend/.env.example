# Environment Variables — GFG Campus Club @ RIT

# ─────────────────────────────────────────────────────────────────────
# HOW TO USE:
#  1. Copy this file:  cp .env.example .env.local
#  2. Fill in the values below in .env.local
#  3. NEVER commit .env.local to version control (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ─── Google Gemini AI ─────────────────────────────────────────────────
# Used for: community assistant chatbot, AI-powered recommendations
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── Firebase Authentication ──────────────────────────────────────────
# Used for: user sign-in, sign-up, and authentication state
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── App Config ───────────────────────────────────────────────────────
# The public URL where the app is deployed (for og:url, canonical links, etc.)
VITE_APP_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────
# NOTE: All variables MUST be prefixed with VITE_ to be accessible
# in the browser via import.meta.env.VITE_*
# ─────────────────────────────────────────────────────────────────────
