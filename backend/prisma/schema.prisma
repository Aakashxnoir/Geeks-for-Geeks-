generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  department    String?
  year          Int?
  role          String   @default("student")
  notifications Notification[]
  stats         CommunityStat?
  achievements  Achievement[]
  eventRegistrations EventRegistration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id          String             @id @default(cuid())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  location    String
  imageUrl    String?
  status      String             @default("upcoming") // upcoming | past
  category    String?
  registrations EventRegistration[]
  createdAt   DateTime           @default(now())
}

model EventRegistration {
  id        String   @id @default(cuid())
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  difficulty  String   // beginner | intermediate | advanced
  linkUrl     String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityStat {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String   @unique
  eventsAttended     Int      @default(0)
  resourcesCompleted Int      @default(0)
  points             Int      @default(0)
  level              Int      @default(1)
  lastActiveAt       DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  name        String
  description String
  badgeType   String?
  earnedAt    DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("new") // new | in_review | closed
  createdAt DateTime @default(now())
}

